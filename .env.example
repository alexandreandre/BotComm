# --- HTTP ---
PORT=8080
NODE_ENV=development
LOG_LEVEL=info
BODY_LIMIT_BYTES=5242880

# --- Supabase (obligatoire si DATABASE_URL : auth JWT + Storage si STORAGE_BACKEND=supabase) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # Project Settings → API → service_role (serveur uniquement)
STORAGE_BACKEND=supabase
DEFAULT_STORAGE_BUCKET=gameplay-videos
# Si STORAGE_BACKEND=gcs :
# GCS_BUCKET=ton-bucket

# --- Postgres Supabase (Project Settings → Database → URI) ---
# Préférer connexion directe :5432 ou session pooler pour Node.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres
DATABASE_SSL=auto

# --- Webhook bot (URL publique du service, sans slash final) ---
PUBLIC_APP_URL=http://localhost:8080

# --- IA (optionnel) ---
GEMINI_API_KEY=

# --- Frontend statique dans l’image Docker ---
# FRONTEND_DIST_PATH=/app/frontend-dist

# --- Bot Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_NAV_TIMEOUT_MS=30000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3
MAX_RUN_TIMEOUT_MS=120000
RUN_CONCURRENCY_LIMIT=2
