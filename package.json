{
  "name": "cinecontent-bot-dispatcher",
  "version": "1.0.0",
  "private": true,
  "description": "Cloud bot backend dispatcher for Lovable/Supabase orchestration",
  "main": "dist/index.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:migrate": "node scripts/run-migration.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@google/generative-ai": "^0.21.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "@supabase/supabase-js": "^2.50.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.50.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
